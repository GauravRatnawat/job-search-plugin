#!/usr/bin/env bash
# Wrapper for job-apply — runs scripts/apply.py
# Works in both Claude Code plugin mode (CLAUDE_PLUGIN_DATA venv) and standalone/Codex mode
set -euo pipefail

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Prefer the plugin venv if it exists (Claude Code plugin mode)
if [[ -x "${CLAUDE_PLUGIN_DATA:-}/venv/bin/python3" ]]; then
  exec "${CLAUDE_PLUGIN_DATA}/venv/bin/python3" "$PLUGIN_DIR/scripts/apply.py" "$@"
fi

# Fall back to system python3 (standalone / Codex mode)
exec python3 "$PLUGIN_DIR/scripts/apply.py" "$@"
